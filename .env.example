POSTGRES_USER="replace-with-db-user"
POSTGRES_PASSWORD="replace-with-db-password"
POSTGRES_DB="curricula_visualiser"
DATABASE_URL="postgresql://replace-with-db-user:replace-with-db-password@localhost:5432/curricula_visualiser?schema=public"
DOCKER_DATABASE_URL="postgresql://replace-with-db-user:replace-with-db-password@postgres:5432/curricula_visualiser?schema=public"
PORT=4000
JWT_SECRET="replace-with-long-random-jwt-secret"
JWT_EXPIRES_IN="1d"
FIT_DIR="../../FIT"
# Optional: import only one admission year, for example current year - 1.
FIT_IMPORT_ADMISSION_YEAR="2025"
FRONTEND_URL="http://localhost:5173"
CORS_ORIGIN="http://localhost:5173"
VITE_API_BASE_URL="http://localhost:4000"

# Vercel production:
# VITE_API_BASE_URL="https://your-railway-backend-domain.com"
#
# Railway production:
# DATABASE_URL="${{Postgres.DATABASE_URL}}"
# JWT_SECRET="replace-with-long-random-jwt-secret"
# JWT_EXPIRES_IN="1d"
# FRONTEND_URL="https://your-vercel-domain.vercel.app"
# CORS_ORIGIN="https://your-vercel-domain.vercel.app"
# PORT=4000
